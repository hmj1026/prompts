{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/plugins/marketplaces/everything-claude-code/skills/continuous-learning-v2/hooks/observe.sh",
            "timeout": 5,
            "statusMessage": "Observing...",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/pre-git-operations-check.sh \"$command\"",
            "timeout": 5,
            "statusMessage": "Checking git operations...",
            "async": false
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/dispatch-bash-pre.sh \"$command\"",
            "timeout": 5,
            "statusMessage": "Pre-command checks...",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/plugins/marketplaces/everything-claude-code/skills/continuous-learning-v2/hooks/observe.sh",
            "timeout": 5,
            "statusMessage": "Observing...",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/dispatch-write.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Post-write checks...",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/dispatch-edit.sh \"$filePath\"",
            "timeout": 30,
            "statusMessage": "Post-edit checks...",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/session-retrospective-reminder.sh",
            "timeout": 5,
            "statusMessage": "Session retrospective...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/git-status-summary.sh",
            "timeout": 10,
            "statusMessage": "Git status summary...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/pre-commit-validation.sh",
            "timeout": 30,
            "statusMessage": "Pre-commit validation...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hooks/compact-reminder.sh",
            "timeout": 3,
            "statusMessage": "Compact reminder...",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
