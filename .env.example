# Prompts Repository 環境設定
# 複製此檔為 .env 並根據您的環境修改路徑

# prompts 專案根目錄 (此專案所在位置)
PROMPTS_ROOT="/home/paul/projects/prompts"

# 用戶根目錄
USER_HOME="/home/paul"

# 專案路徑對應
# deploy.sh 使用這些路徑決定 symlink 目標
PROJECT_zdpos_dev="/home/paul/projects/zdpos_dev"
PROJECT_ccas="/home/paul/projects/ccas"
PROJECT_docker_run="/home/paul/projects/docker_run"
PROJECT_line_bot="/home/paul/projects/line-bot"

# WSL 路徑範例 (如果專案在 Windows 磁碟上):
# PROJECT_zdpos_dev="/mnt/e/projects/zdpos_dev"
